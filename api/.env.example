# =====================================================
# Configurações do Banco de Dados
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
# =====================================================
DATABASE_URL="postgresql://postgres:sua_senha@localhost:5432/routinia"

# =====================================================
# Configurações da Aplicação
# =====================================================
PORT=3333
NODE_ENV=development

# =====================================================
# JWT - Token de Autenticação
# Use um segredo longo e aleatório em produção!
# Gere um com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =====================================================
JWT_SECRET=seu_segredo_super_secreto_aqui_troque_em_producao
JWT_EXPIRES_IN=7d

# =====================================================
# URL do Frontend (para links nos emails)
# =====================================================
WEB_URL=http://localhost:5173

# =====================================================
# Configurações de Email (SMTP)
# Para testes locais, use o Ethereal: https://ethereal.email
# Para produção, recomendamos Resend (https://resend.com) ou SendGrid
# =====================================================
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_usuario_smtp
SMTP_PASS=sua_senha_smtp
EMAIL_FROM="Routinia <noreply@routinia.app>"
